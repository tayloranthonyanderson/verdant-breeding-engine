# Copy to .env and adjust. Never commit real secrets.

# --- API / database ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=breeding
# PGUSER=youruser
# PGPASSWORD=
# Or a single URL (overrides the PG* vars), e.g. on fly.io / managed Postgres:
# DATABASE_URL=postgresql://user:pass@host:5432/breeding

PORT=8000

# --- AI assistant (Anthropic Claude) ---
# Required for the chat assistant to work. Without it the app still analyzes;
# the assistant just reports it isn't configured.
# ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
